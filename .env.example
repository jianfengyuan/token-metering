PORT=3000
DATABASE_PATH=./data/token-metering.db

# Local simulator (same app) for no-provider development
LOCAL_SIMULATOR_BASE_URL=http://127.0.0.1:3000/simulator/v1
LOCAL_SIMULATOR_API_KEY=local-dev

# Optional real local provider (Ollama OpenAI-compatible endpoint)
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_API_KEY=local-dev

# Optional model-specific Hugging Face tokenizers.
# Keys are matched against the requested model name, so "gemma" matches "gemma-2-2b".
HF_TOKENIZER_PATHS={"gemma":"./tokenizers/gemma/tokenizer.json"}
HF_TOKENIZER_CONFIG_PATHS={"gemma":"./tokenizers/gemma/tokenizer_config.json"}
HF_TOKENIZER_REPOS={"gemma":"google/gemma-4-e2b-it"}
HF_TOKENIZER_REVISIONS={"gemma":"main"}
# Optional for private/gated Hugging Face repos
# HF_TOKEN=<your_hf_token>
