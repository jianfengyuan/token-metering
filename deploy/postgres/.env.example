# ============================================================================
# token-metering PostgreSQL 部署环境变量示例
# 使用：cp .env.example .env，然后修改下面的占位值。
# .env 已被 .gitignore 忽略，不会提交到仓库。
# ============================================================================

# 数据库用户名
PG_USER=admin

# 数据库密码（必填，请替换为强随机密码，例如：openssl rand -base64 24）
PG_PASSWORD=admin

# 数据库名
PG_DATABASE=token_metering

# 宿主机映射端口
PG_PORT=5432

# 镜像版本（生产环境建议钉到具体小版本，如 postgres:17.5）
PG_IMAGE=postgres:17

# 容器名（可选）
PG_CONTAINER_NAME=token-metering-pg
